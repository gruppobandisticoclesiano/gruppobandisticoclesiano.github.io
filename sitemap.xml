---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign pages = site.pages | sort: 'url' -%}
{%- for page in pages -%}
{%- unless page.url contains '/404.html' or page.robots contains 'noindex' or page.sitemap == false %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
  </url>
{%- endunless -%}
{%- endfor %}
</urlset>
